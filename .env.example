# Server-side only. Never prefix with VITE_ or it will be bundled into the
# client build and exposed in the browser. Set the real value as a Base44
# Dashboard -> Secrets entry (or your backend function's env), never here.
OPENAI_API_KEY=

# WhatsApp support number for the floating widget (digits only, with country
# code, e.g. 9665XXXXXXXX). Safe to expose to the frontend.
VITE_WHATSAPP_NUMBER=

# Real Estate Opportunities Phase 1 feature flags.
# Keep false until the admin-managed teaser module is ready to be exposed.
VITE_REAL_ESTATE_OPPORTUNITIES_ENABLED=false
REAL_ESTATE_OPPORTUNITIES_ENABLED=false
